generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Collection {
  id        String   @id @default(cuid())
  name      String
  icon      String? // emoji, or a /uploads path for a custom collection image
  color     String? // hex color, used when no icon is set
  view      String   @default("cards") // "cards" | "list" | "headlines" | "moodboard"
  sort      String   @default("manual") // "manual" | "newest" | "oldest" | "title-asc" | "title-desc"
  parentId  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  shareSlug String?  @unique // set => this collection's bookmarks are publicly readable at /share/<shareSlug>

  parent    Collection?  @relation("CollectionChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Collection[] @relation("CollectionChildren")
  bookmarks Bookmark[]

  @@index([parentId])
}

model Bookmark {
  id             String   @id @default(cuid())
  url            String
  title          String
  description    String?
  note           String?
  domain         String?
  faviconPath      String?
  faviconCheckedAt DateTime? // set on every refresh attempt (success or fail) so failures aren't retried forever
  coverImagePath   String?
  coverImageCheckedAt DateTime? // set on every refresh attempt (success or fail), same reasoning as faviconCheckedAt
  collectionId     String?
  sortOrder        Int       @default(0) // manual drag order, meaningful only among bookmarks sharing the same collectionId (including null = Unsorted)
  deletedAt        DateTime? // soft-delete: set instead of removing the row; excluded from all normal queries
  isBroken         Boolean   @default(false)
  linkCheckedAt    DateTime? // set on every link-check attempt regardless of outcome, for the same reason as faviconCheckedAt
  isFavorite       Boolean   @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  collection Collection?   @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  tags       BookmarkTag[]

  @@index([collectionId])
  @@index([deletedAt])
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  bookmarks BookmarkTag[]
}

model BookmarkTag {
  bookmarkId String
  tagId      String

  bookmark Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookmarkId, tagId])
  @@index([tagId])
}

// A pinned, named shortcut back into /search?q=<query> — the query string
// is whatever the full-text search box accepts, saved verbatim.
model SavedSearch {
  id        String   @id @default(cuid())
  name      String
  query     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Settings {
  id               Int     @id @default(1)
  apiToken         String
  iconsSeeded      Boolean @default(false)
  accentColor      String  @default("blue")
  colorScheme      String  @default("dark")
  density          String  @default("comfortable")
  gridPattern      String  @default("none")
  defaultLandingView         String  @default("all") // "all" | "unsorted" | "stats" | "collection"
  defaultLandingCollectionId String? // set when defaultLandingView = "collection"; not FK-enforced so a deleted collection just falls back to "all"
  authUsername     String?
  authPasswordHash String?
  sessionSecret    String?
  autoScanEnabled       Boolean   @default(true)
  autoScanIntervalHours Int       @default(24)
  lastAutoScanAt        DateTime?
  lastAutoScanSummary   Json? // { faviconsFound, coversFound, linksChecked, brokenLinksFound, errors }, from the most recent scheduled run
}

// User-uploaded icons for the collection icon picker, organized into
// categories (typically one per subfolder when bulk-uploading a folder).
model IconAsset {
  id        String   @id @default(cuid())
  category  String
  path      String
  filename  String
  createdAt DateTime @default(now())

  @@index([category])
}
